{
  "name": "firewolf-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "nuxt typecheck",
    "generate:api-types": "curl -o app/lib/api/openapi.json http://localhost:8087/firewolf/v3/api-docs && openapi-typescript app/lib/api/openapi.json -o app/lib/api/schema.ts && prettier --write app/lib/api/schema.ts",
    "prebuild": "pnpm generate:api-types"
  },
  "dependencies": {
    "@nuxt/icon": "^2.0.0",
    "@nuxt/ui": "4.2.0",
    "@pinia/nuxt": "^0.5.5",
    "@vee-validate/yup": "^4.15.1",
    "@vueuse/core": "^13.9.0",
    "firebase": "^12.1.0",
    "nuxt": "^4.0.3",
    "nuxt-vuefire": "^1.1.0",
    "pinia": "^2.2.7",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "vee-validate": "^4.15.1",
    "vue": "latest",
    "vuefire": "^3.2.2",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@nuxt/eslint": "^1.9.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.28.0",
    "openapi-typescript": "^7.9.1",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.7.2",
    "vue-tsc": "^3.0.6"
  },
  "pnpm": {
    "overrides": {
      "@vueuse/core": "13.9.0",
      "@vueuse/shared": "13.9.0"
    }
  }
}
