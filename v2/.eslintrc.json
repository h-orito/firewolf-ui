{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["prettier", "@typescript-eslint"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "ignorePatterns": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.spec.ts",
    "tests/e2e/**/*"
  ],
  "rules": {
    "prettier/prettier": "error",
    "no-explicit-any": "off",
    "@typescript-eslint/no-unnecessary-condition": "error"
  }
}
