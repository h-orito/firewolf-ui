    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.0.0",
    "lucide-react": "^0.525.0",
    "next": "15.2.0",
    "next-pwa": "^5.6.0",
    "openapi-fetch": "^0.14.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
